<% layout("/layouts/boilerplate") -%>
<body>
    <h3>Create A New List :</h3>
    <form method="POST" action="/listing">
        <input name="listing[title]" placeholder="Enter Title"type="text"><br>
        <textarea name="listing[description]" placeholder="Enter description" type="text"></textarea><br>
        <input name="listing[image]" placeholder="Enter image"><br>
        <input name="listing[price]" placeholder="Enter price" type="number"><br>
        <input name="listing[location]" placeholder="Enter location"type="text"><br>
        <input name="listing[country]" placeholder="Enter country"type="text"><br>
        <button>Add</button>
    </form>
</body>
